{
  "name": "loop-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "Loop Solar Energy Lead Management Platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@loop/api",
    "db:migrate": "turbo run db:migrate --filter=@loop/api",
    "db:seed": "turbo run db:seed --filter=@loop/api"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "protobufjs",
      "@nestjs/core",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  }
}
